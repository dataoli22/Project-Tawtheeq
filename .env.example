# Local Hardhat network (started via `npm run node` in /contracts)
RPC_URL=http://127.0.0.1:8545

# Hardhat's well-known deterministic test accounts (account #0 and #1 from the
# default mnemonic). Public, funded only on the local dev chain — never use
# on a real network.
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
ORACLE_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Chatbot provider selection. "auto" (default) picks the first hosted
# provider below with a key set, then falls back to local Ollama, then to a
# deterministic rule-based explainer if nothing is reachable. Set to one of
# anthropic|openai|gemini|groq|ollama to pin a specific provider first.
CHAT_PROVIDER=auto

# Set whichever of these you want to use — leave the rest blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Local Ollama fallback (zero API cost) — needs `ollama serve` running and a
# model pulled, e.g. `ollama pull llama3`. Used automatically if no hosted
# provider key is set, or if the hosted call fails (quota/network/bad key).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

DATABASE_PATH=./tawtheeq.db
